{
  "layer": "top",

  // Left side modules
  "modules-left": ["custom/appmenu","cpu","custom/network"],

  // Center (optional)
  "modules-center": ["custom/wifi","custom:separator","hyprland/workspaces","custom:separator","bluetooth"],

  // Right side modules
  "modules-right": ["custom/notification","battery", "clock","custom/power"],

  // App launcher (custom menu)
  "custom/appmenu": {
    "format": "َ°»€",
    "tooltip": "App Menu",
    "on-click": "~/.config/waybar/runrofi.sh",
    "interval": 999999
  },

// custom power 
  "custom/power": {
    "format": "ï€‘ ",
    "tooltip": false,
    // "tooltip-format": "Power Menu",
    "on-click": "~/.config/waybar/scripts/power-menu.sh"
  },


// network-speed


"custom/network": {
  "exec": "~/.config/waybar/scripts/network.sh",
  "interval": 1,
  "return-type": "json"
},



// Battery


    "battery": {
    "states": {
      "warning": 20,
      "critical": 10
